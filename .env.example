NODE_ENV=development
PORT=5000

# Local PostgreSQL connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/admin_control_hub
SESSION_SECRET=change-me-to-a-long-random-secret

# Public base URL used for OAuth callbacks and generated links
# For local Cursor dev:
APP_URL=http://localhost:5000

# Optional: also supported as fallbacks
# SITE_URL=http://localhost:5000
# PUBLIC_BASE_URL=http://localhost:5000

# OAuth / integrations (fill only what you use)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# GROQ_API_KEY=
