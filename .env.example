NODE_ENV=development
PORT=5000

# Local PostgreSQL connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/admin_control_hub

# IMPORTANT: Set this to a strong random value in production (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-secret

# Public base URL used for OAuth callbacks and generated links
# For local Cursor dev:
APP_URL=http://localhost:5000

# Optional: also supported as fallbacks
# SITE_URL=http://localhost:5000
# PUBLIC_BASE_URL=http://localhost:5000

# OAuth / integrations (fill only what you use)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# META_APP_ID=
# META_APP_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# GROQ_API_KEY=
# ANTHROPIC_API_KEY=
# ANTHROPIC2_API_KEY=
# OPENROUTER_API_KEY=
# RUNWARE_API_KEY=
# GOOGLE_API_KEY_IMAGE=
# APIFY_TOKEN=
# APIFY_INSTAGRAM_TOKEN=

# ─── Security ─────────────────────────────────────────────────────────────────
# Encryption key for OAuth tokens stored in DB (64 hex chars = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# TOKEN_ENCRYPTION_KEY=

# Email for all outgoing emails (OTP, password reset, alerts, marketing)
# Emails will be sent FROM: support@oravini.com
# The EMAIL_USER/EMAIL_PASS is used for SMTP authentication only.
# To send as support@oravini.com, add it as a "Send mail as" alias in Gmail settings,
# or use Google Workspace with support@oravini.com as a real mailbox.
# EMAIL_USER=
# EMAIL_PASS=

# ─── LiveKit (Webinar Streaming) ──────────────────────────────────────────────
# Sign up at https://cloud.livekit.io for a free account
# Or self-host: https://docs.livekit.io/home/self-hosting/
LIVEKIT_URL=wss://your-app.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret
