{
  "include": ["client/src/**/*", "shared/**/*", "server/**/*"],
  "exclude": [
    "node_modules", "build", "dist", "**/*.test.ts",
    "shared/adminSchedulingTab.ts",
    "shared/advancedSchedulingFeatures.ts",
    "shared/showUpOptimization.ts",
    "shared/schedulingSystem.ts",
    "shared/schedulingUI.ts",
    "shared/schedulingDemo.ts",
    "shared/teamScalingSystem.ts",
    "shared/stepByStepProjectTracker.ts",
    "shared/shared/**/*"
  ],
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": true,
    "target": "ES2017",
    "downlevelIteration": true,
    "module": "ESNext",
    "strict": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"]
    }
  }
}
