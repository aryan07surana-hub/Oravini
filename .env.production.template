# Production Environment Variables for Render
# Copy these to Render Dashboard → Your Service → Environment tab

# REQUIRED - Database (get this from your Render PostgreSQL service)
DATABASE_URL=postgresql://user:password@host:5432/database

# REQUIRED - Session security
SESSION_SECRET=change-this-to-a-long-random-string-min-32-chars

# REQUIRED - Environment
NODE_ENV=production

# REQUIRED - Your domain
APP_URL=https://oravini.com

# REQUIRED - Port (Render uses 10000 by default)
PORT=10000

# OPTIONAL - Google OAuth (if you use Google login)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# OPTIONAL - Other OAuth providers
# META_APP_ID=
# META_APP_SECRET=
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=

# REQUIRED - AI APIs (Ulama/LLB — powers all AI features including Clip Finder)
ULAMA_API_KEY=sk-your-ulama-key-here

# OPTIONAL - Additional AI APIs
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# GOOGLE_API_KEY_IMAGE=

# OPTIONAL - LiveKit (Webinar Streaming - unlimited viewers, 4K, no duration limits)
# Sign up at https://cloud.livekit.io for free
LIVEKIT_URL=wss://your-app.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret
